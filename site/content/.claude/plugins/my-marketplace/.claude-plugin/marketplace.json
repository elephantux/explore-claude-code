{
  // .claude-plugin/marketplace.json — Каталог маркетплейса
  //
  // Этот файл определяет маркетплейс плагинов: каталог, который перечисляет
  // плагины и указывает Claude Code, откуда их загружать. Разместите это
  // в git-репозитории и поделитесь с командой или сообществом.
  //
  // Пользователи добавляют ваш маркетплейс:
  //   /plugin marketplace add owner/repo
  //
  // Затем устанавливают отдельные плагины:
  //   /plugin install review-plugin@my-marketplace

  // ── Идентичность маркетплейса ───────────────────────────────────────

  // Публичное имя (kebab-case). Пользователи видят его при установке:
  //   /plugin install <plugin>@my-marketplace
  "name": "my-marketplace",

  // Кто поддерживает этот маркетплейс
  "owner": {
    "name": "Ваша Команда",
    "email": "team@example.com"
  },

  // ── Опциональные метаданные ──────────────────────────────────────
  "metadata": {
    "description": "Стартовый маркетплейс, показывающий формат каталога",
    "version": "1.0.0",

    // Базовая директория для относительных источников плагинов.
    // С этой настройкой "source": "review-plugin" разрешается в "./plugins/review-plugin"
    "pluginRoot": "./plugins"
  },

  // ── Каталог плагинов ───────────────────────────────────────────
  //
  // Каждая запись нуждается как минимум в name и source.
  // Вы также можете включить любое поле из схемы plugin.json.

  "plugins": [

    // ── Источник с относительным путём ─────────────────────────────────
    // Плагин живёт в том же репозитории, что и маркетплейс.
    // Простейший вариант для самодостаточных маркетплейсов.
    {
      "name": "review-plugin",
      "source": "./plugins/review-plugin",
      "description": "Добавляет навык /review для быстрого код-ревью",
      "version": "1.0.0"
    },

    // ── Источник GitHub ────────────────────────────────────────────
    // Плагин живёт в отдельном GitHub-репозитории.
    // Поддерживает ref (ветка/тег) и sha (точный коммит) pinning.
    {
      "name": "deploy-tools",
      "source": {
        "source": "github",
        "repo": "your-org/deploy-plugin",
        "ref": "v2.0.0"
      },
      "description": "Автоматизация деплоя и управление окружениями",
      "category": "devops",
      "tags": ["deploy", "ci", "automation"]
    },

    // ── Источник npm ───────────────────────────────────────────────
    // Плагин распространяется как npm-пакет.
    // Поддерживает диапазоны версий и пользовательские реестры.
    {
      "name": "lint-plugin",
      "source": {
        "source": "npm",
        "package": "@your-org/claude-lint-plugin",
        "version": "^1.0.0"
      },
      "description": "Авто-линтинг хуки для JavaScript и TypeScript"
    }

    // Другие типы источников:
    //
    //   Git URL:
    //   { "source": "url", "url": "https://gitlab.com/team/plugin.git" }
    //
    //   Git поддиректория (sparse clone для монорепозиториев):
    //   { "source": "git-subdir", "url": "https://...", "path": "tools/plugin" }
    //
    //   pip:
    //   { "source": "pip", "package": "my-plugin" }
  ]
}
