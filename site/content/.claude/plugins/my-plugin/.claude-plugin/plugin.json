{
  // .claude-plugin/plugin.json — Манифест плагина
  //
  // Этот файл определяет идентичность вашего плагина. Claude Code использует его
  // для отображения плагина в менеджере плагинов, создания пространства имён
  // для навыков и отслеживания версий для обновлений.
  //
  // Это ЕДИНСТВЕННЫЙ файл, который находится внутри .claude-plugin/.
  // Все директории компонентов (skills/, agents/, hooks/ и т.д.)
  // живут в корне плагина, НЕ внутри этой директории.

  // ── Обязательные поля ────────────────────────────────────────────

  // Уникальный идентификатор. Также становится префиксом пространства имён навыков.
  // Навык "review" в этом плагине → /my-plugin:review
  "name": "my-plugin",

  // Показывается в менеджере плагинов при просмотре или установке.
  "description": "Стартовый плагин, показывающий формат манифеста и доступные поля",

  // Семантическое версионирование: major.minor.patch
  // Увеличивайте major для ломающих изменений, minor для новых возможностей, patch для исправлений.
  // Claude Code использует это для обнаружения обновлений.
  "version": "1.0.0",

  // ── Опциональные метаданные ──────────────────────────────────────

  // Атрибуция. Показывается в деталях плагина.
  "author": {
    "name": "Ваше Имя",
    "email": "you@example.com"
  },

  // URL документации для вашего плагина
  "homepage": "https://github.com/your-org/my-plugin#readme",

  // Репозиторий с исходным кодом
  "repository": "https://github.com/your-org/my-plugin",

  // SPDX идентификатор лицензии (MIT, Apache-2.0 и т.д.)
  "license": "MIT",

  // Теги для обнаружения и категоризации в маркетплейсах
  "keywords": ["starter", "example", "scaffold"]

  // ── Переопределения компонентов (продвинутое) ─────────────────────────────
  //
  // По умолчанию Claude Code обнаруживает компоненты, сканируя
  // стандартные директории в корне плагина:
  //   skills/    → Agent Skills
  //   commands/  → Слэш-команды
  //   agents/    → Пользовательские агенты
  //   hooks/     → hooks.json обработчики событий
  //   .mcp.json  → Конфиги MCP-серверов
  //   .lsp.json  → Конфиги LSP-серверов
  //
  // Вы можете переопределить это явными путями:
  //
  //   "commands": ["./commands/core/", "./commands/extra/review.md"],
  //   "agents": ["./agents/security-reviewer.md"],
  //   "hooks": { "PostToolUse": [...] },
  //   "mcpServers": { "my-db": { "command": "..." } },
  //   "lspServers": { "go": { "command": "gopls" } }
  //
  // Большинству плагинов это не нужно — настройки по умолчанию работают.
}
