{
  // Разрешения контролируют, какие инструменты Claude может использовать без запроса.
  // Каждая запись — это glob-паттерн, сопоставляемый с инструментом + аргументами.
  "permissions": {
    "allow": [
      // Позволить Claude читать любой файл без запроса
      "Read",
      // Позволить Claude свободно искать файлы
      "Glob",
      "Grep",
      // Позволить Claude запускать набор тестов
      "Bash(npm test)",
      "Bash(npm run lint)",
      // Позволить Claude запускать dev-сервер
      "Bash(npm run dev)",
      // Разрешить git status и diff (только чтение git)
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)"
    ],
    "deny": [
      // Никогда не позволять Claude пушить в удалённый репозиторий
      "Bash(git push*)",
      // Никогда не позволять Claude устанавливать пакеты без запроса
      "Bash(npm install*)",
      // Блокировать деструктивные git-команды
      "Bash(git reset --hard*)",
      "Bash(git clean*)"
    ]
  },

  // Конфигурация API
  "model": "claude-sonnet-4-6",
  "maxTokens": 16384,

  // Хуки запускают пользовательские скрипты в определённых точках рабочего процесса Claude.
  // Смотрите .claude/hooks/ для полного обзора и примеров скриптов.
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/my-hook.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "npm run lint --fix",
            "async": true
          }
        ]
      }
    ]
  }
}
