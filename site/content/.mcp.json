{
  // .mcp.json — Конфигурация MCP на уровне проекта
  //
  // MCP (Model Context Protocol) подключает Claude к внешним инструментам,
  // API и источникам данных. Каждый «сервер» предоставляет набор инструментов,
  // которые Claude может обнаруживать и вызывать во время сессии.
  //
  // Этот файл располагается в корне вашего проекта. Закоммитьте его
  // в систему контроля версий, чтобы каждый член команды получил
  // одинаковую конфигурацию инструментов.
  //
  // Поддерживаются три типа серверов:
  //   "http"    — Удалённый HTTP-сервер (рекомендуется для удалённых инструментов)
  //   "command" — Локальный stdio-процесс (запускается для каждой сессии)
  //   "url"     — SSE-эндпоинт (устарело, используйте http вместо него)
  //
  // Устанавливайте серверы через CLI вместо ручного редактирования:
  //   claude mcp add my-server -s project -- npx some-mcp-package
  //
  // Области видимости (scope) определяют, кто видит каждый сервер:
  //   -s local    — Только вы, эта машина (~/.claude.json)
  //   -s project  — Все в проекте (.mcp.json, закоммичен)
  //   -s user     — Только вы, все ваши проекты (~/.claude/settings.json)
  //
  // Управляйте серверами в сессии с помощью слэш-команды /mcp.

  "mcpServers": {

    // ── HTTP-сервер (рекомендуется для удалённых сервисов) ──────────
    // Подключается к удалённому HTTP-эндпоинту. Поддерживает OAuth,
    // если сервер требует аутентификации. Claude обрабатывает процесс.
    "my-remote-service": {
      "type": "http",
      "url": "https://my-service.example.com/mcp"
    },

    // ── stdio-сервер (для локальных инструментов) ─────────────────────────
    // Запускает локальный процесс. Claude общается через stdin/stdout.
    // Большинство npm/pip MCP-пакетов используют этот транспорт.
    "my-local-tool": {
      "command": "npx",
      "args": ["-y", "@example/mcp-server-tool"],
      "env": {
        // Переменные окружения поддерживают синтаксис подстановки:
        //   ${env:VAR}            — читает из вашего окружения shell
        //   ${env:VAR:-default}   — использует "default", если не задано
        "API_KEY": "${env:MY_TOOL_API_KEY}",
        "DATABASE_URL": "${env:DATABASE_URL:-postgresql://localhost:5432/mydb}"
      },
      // Опционально: задать рабочую директорию для запускаемого процесса
      "cwd": "/path/to/working/directory"
    },

    // ── Реальные примеры ────────────────────────────────────
    // Популярные серверы сообщества, которые вы можете добавить:
    //
    //   claude mcp add github -s project -- npx -y @modelcontextprotocol/server-github
    //   claude mcp add postgres -s local -- npx -y @modelcontextprotocol/server-postgres
    //   claude mcp add sentry -s project -- npx -y @sentry/mcp-server-sentry
    //
    // Просмотреть доступные серверы: https://github.com/modelcontextprotocol/servers

    // ── Поиск инструментов ────────────────────────────────────────────
    // Когда MCP-серверы предоставляют много инструментов, Claude использует
    // Tool Search для поиска нужных вместо загрузки всех. Это происходит
    // автоматически для серверов с 30+ инструментами. Для настройки:
    //
    //   "toolSearch": {
    //     "enabled": "auto",        — "auto" (по умолчанию), true или false
    //     "threshold": 30           — количество инструментов, при котором включается поиск
    //   }

    // ── MCP-ресурсы ──────────────────────────────────────────
    // Некоторые серверы предоставляют данные как ресурсы (документы, схемы и т.д.).
    // Ссылайтесь на них в промпте через @server-name:resource-id
    // чтобы подключить эти данные в контекст.

    // ── MCP-промпты ────────────────────────────────────────────
    // Серверы могут предоставлять переиспользуемые шаблоны промптов,
    // которые появляются как слэш-команды. Запустите /mcp в сессии,
    // чтобы увидеть доступные промпты.
  }
}
